{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user on the platform (Customer, Vehicle Owner, or Admin).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "owner", "admin"] },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Represents a vehicle listed for rent.",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "ownerId": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "pricePerDay": { "type": "number" },
        "availabilityStatus": { "type": "string", "enum": ["available", "unavailable"] },
        "location": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vehicleId", "ownerId", "category", "pricePerDay", "availabilityStatus"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Represents a rental booking request.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "customerId": { "type": "string" },
        "ownerId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "paid", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "customerId", "vehicleId", "startDate", "endDate", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a payment transaction for a booking.",
      "type": "object",
      "properties": {
        "paymentId": { "type": "string" },
        "bookingId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "verified", "failed"] },
        "transactionReference": { "type": "string" },
        "verifiedByAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["paymentId", "bookingId", "userId", "amount", "paymentStatus"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicle listings"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Rental bookings"
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment transactions"
    }
  }
}
