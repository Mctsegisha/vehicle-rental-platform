rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.role in ['customer', 'owner', 'admin']
        && (data.status == 'active' || data.status == 'inactive');
    }

    function isValidVehicle(data) {
      return data.ownerId == request.auth.uid
        && data.category is string && data.category.size() <= 50
        && data.pricePerDay is number && data.pricePerDay > 0
        && data.availabilityStatus in ['available', 'unavailable'];
    }

    function isValidBooking(data) {
      return data.customerId == request.auth.uid
        && data.status in ['pending', 'approved', 'rejected', 'paid', 'completed']
        && data.startDate is string // Simple date string check
        && data.endDate is string;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid
        && data.amount is number && data.amount > 0
        && data.paymentStatus in ['pending', 'verified', 'failed'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'status', 'role']); // Security: Role change should be restricted in real app but keeping simple here
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidVehicle(incoming());
      allow update: if isSignedIn() && (isOwner(existing().ownerId) || isAdmin()) && isValidVehicle(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().ownerId) || isAdmin());
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isOwner(resource.data.customerId) || isOwner(resource.data.ownerId) || isAdmin());
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if isSignedIn() && (
        // Customer can cancel or update until it's approved
        (isOwner(existing().customerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Owner can approve/reject
        (isOwner(existing().ownerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidPayment(incoming());
      allow update: if isAdmin(); // Only admin can verify/update payments
    }
  }
}
